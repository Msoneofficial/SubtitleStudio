# Subtitle Studio Environment Configuration
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env in the root of your project (same level as pubspec.yaml)
# 2. Fill in your own values for the variables below
# 3. Never commit the .env file to version control (it's already in .gitignore)
# 4. Rebuild the app for changes to take effect
#
# Telegram Bot Configuration (Optional)
# Used for sending bug reports directly to the developer's channel
# Leave empty or commented out to disable Telegram bug reporting feature
# Get your bot token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Channel ID where bug reports will be sent
# Format: Use -100 prefix for private channels (e.g., -1002345678901)
# You can find your channel ID by forwarding a message to @userinfobot
TELEGRAM_CHANNEL_ID=your_telegram_channel_id_here

# API Configuration
# Add any other API keys or credentials needed for your deployment
# API_KEY=your_api_key_here
# API_SECRET=your_api_secret_here
